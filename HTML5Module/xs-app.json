{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/facts/(.*)$",
      "target": "/$1",
      "destination": "Facts",
      "authenticationType": "xsuaa",
      "scope": "$XSAPPNAME.Test-Access"

    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa",v
    }
  ]
}